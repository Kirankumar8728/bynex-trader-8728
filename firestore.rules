rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 
          && data.email is string && data.email.size() <= 256
          && data.createdAt is int;
    }
    
    function isValidAccount(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.balance is number && data.balance >= 0
          && data.currency is string && data.currency.size() == 3
          && data.isActive is bool;
    }

    function isValidTrade(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.contractId is string && data.contractId.size() <= 128
          && data.symbol is string && data.symbol.size() <= 32
          && data.type is string && data.type.size() <= 16
          && data.buyPrice is number && data.buyPrice >= 0
          && data.status in ['open', 'won', 'lost', 'sold']
          && data.createdAt is int;
    }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- User Collections ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
      
      // Subcollections
      match /accounts/{accountId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAccount(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && isValidAccount(incoming()) && incoming().userId == userId
                       && incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'isActive']);
      }
      
      match /trades/{tradeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(tradeId) && isValidTrade(incoming()) && incoming().userId == userId;
        allow update: if isOwner(userId) && existing().status == 'open' && isValidTrade(incoming()) && incoming().userId == userId
                       && incoming().diff(existing()).affectedKeys().hasOnly(['sellPrice', 'status', 'exitTick', 'exitTime', 'profit']);
      }
    }

    // --- Public / Test Collections ---
    match /test/connection {
      allow get: if true; // Allow anyone to check connection
    }

    match /withdrawals/{withdrawalId} {
      // Currently withdrawals are managed via server-side (firebase-admin), 
      // but we define basic rules here in case of client-side access.
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    function isAdmin() {
      // Basic admin check - can be expanded as needed
      return isSignedIn() && (request.auth.token.email == 'kirankumar8728@gmail.com');
    }
  }
}
